@{
    ViewData["Title"] = "Cài đặt hệ thống";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Cài đặt hệ thống</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-hdd-network me-2"></i>Quản lý Dữ liệu hệ thống</h5>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="p-4 border rounded-3 bg-light h-100">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary text-white rounded-circle p-2 me-3">
                                <i class="bi bi-cloud-download fs-4"></i>
                            </div>
                            <h5 class="mb-0">Sao lưu (Backup)</h5>
                        </div>
                        <p class="text-muted small">Xuất toàn bộ dữ liệu (Người dùng, Lịch khám, Bác sĩ) ra file để lưu trữ trên máy tính của bạn.</p>
                        <a asp-controller="System" asp-action="BackupData" class="btn btn-primary w-100">
                            <i class="bi bi-download me-2"></i>Tải bản sao lưu 
                        </a>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-4 border rounded-3 bg-light h-100">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-warning text-dark rounded-circle p-2 me-3">
                                <i class="bi bi-cloud-upload fs-4"></i>
                            </div>
                            <h5 class="mb-0">Phục hồi (Restore)</h5>
                        </div>
                        <p class="text-muted small">Chọn file đã sao lưu trước đó để nạp lại dữ liệu vào hệ thống (Dữ liệu hiện tại sẽ bị ghi đè).</p>
                        <form asp-controller="System" asp-action="RestoreData" method="post" enctype="multipart/form-data">
                            <div class="mb-3">
                                <input type="file" name="backupFile" class="form-control form-control-sm" accept=".json" required />
                            </div>
                            <button type="submit" class="btn btn-warning w-100">
                                <i class="bi bi-upload me-2"></i>Bắt đầu phục hồi
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>