@model IEnumerable<BenhvienSmart.Models.User>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-people-fill"></i> Quản lý Bệnh nhân</h2>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Họ và Tên</th>
                        <th>Giới tính</th>
                        <th>Tuổi</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th class="text-center">Số lần khám</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3">
                                <span class="fw-bold text-dark">@item.FullName</span>
                            </td>
                            <td>
                                @if (item.Gender == "Nam")
                                {
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Nam</span>
                                }
                                else if (item.Gender == "Nữ")
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Nữ</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border">@item.Gender</span>
                                }
                            </td>
                            <td>
                                @if (item.DateOfBirth.HasValue)
                                {
                                    var age = DateTime.Now.Year - item.DateOfBirth.Value.Year;
                                    // Kiểm tra nếu chưa đến sinh nhật trong năm nay thì trừ 1
                                    if (item.DateOfBirth.Value.Date > DateTime.Now.AddYears(-age)) age--;
                                    <span>@age tuổi</span>
                                }
                                else
                                {
                                    <span class="text-muted small"><em>Chưa cập nhật</em></span>
                                }
                            </td>
                            <td>@item.Email</td>
                            <td>@item.PhoneNumber</td>
                            <td class="text-center">
                                <span class="badge rounded-pill bg-info text-dark">@item.Appointments?.Count</span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-file-earmark-medical"></i> Hồ sơ
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa bệnh nhân này?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>