@model BenhvienSmart.Models.User

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center">
                    <i class="bi bi-person-circle" style="font-size: 5rem; color: #0d6efd;"></i>
                    <h4 class="mt-2">@Model.FullName</h4>
                    <p class="text-muted">Bệnh nhân</p>
                    <hr />
                    <div class="text-start">
                        <p><strong>Email:</strong> @Model.Email</p>
                        <p><strong>SĐT:</strong> @Model.PhoneNumber</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h5 class="mb-0 text-primary">Lịch sử khám bệnh & Hồ sơ y tế</h5>
                </div>
                <div class="card-body">
                    @if (Model.Appointments != null && Model.Appointments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ngày khám</th>
                                        <th>Bác sĩ</th>
                                        <th>Lý do khám</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var app in Model.Appointments.OrderByDescending(a => a.AppointmentDate))
                                    {
                                        <tr>
                                            <td>@app.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@app.Doctor?.FullName</td>
                                            <td>@app.Note</td>
                                            <td>
                                                <span class="badge @(app.Status == AppointmentStatus.Completed ? "bg-success" : "bg-warning")">
                                                    @app.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">Bệnh nhân này chưa có lịch sử khám bệnh.</p>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    </div>
</div>