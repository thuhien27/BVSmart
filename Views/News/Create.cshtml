@model BenhvienSmart.Models.News

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold">Soạn thảo bản tin mới</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tiêu đề</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Tóm tắt ngắn</label>
                    <textarea asp-for="Summary" class="form-control" rows="2" placeholder="Hiển thị ngoài trang chủ..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Nội dung chi tiết</label>
                    <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">URL Ảnh minh họa</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="Dán link ảnh tại đây..." />
                </div>

                <div class="d-flex justify-content-between pt-3">
                    <a asp-action="AdminIndex" class="btn btn-outline-secondary">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary px-4">Đăng tin ngay</button>
                </div>
            </form>
        </div>
    </div>
</div>