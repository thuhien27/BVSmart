@model IEnumerable<BenhvienSmart.Models.Department>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-hospital"></i> Quản lý Chuyên khoa</h2>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Thêm khoa mới</a>
    </div>

    <div class="card shadow-sm border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">ID</th>
                    <th>Tên chuyên khoa</th>
                    <th>Mô tả</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">@item.Id</td>
                        <td><strong>@item.Name</strong></td>
                        <td>@item.Description</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-white">Sửa</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa khoa này có thể ảnh hưởng đến dữ liệu bác sĩ. Tiếp tục?')">
                                    <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>