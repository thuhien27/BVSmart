@model BenhvienSmart.Models.Contact

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">LIÊN HỆ & GÓP Ý</h2>
        <p class="text-muted">Chúng tôi luôn lắng nghe ý kiến của bạn để hoàn thiện dịch vụ mỗi ngày</p>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white h-100">
                <h4 class="fw-bold mb-4">Thông tin liên hệ</h4>
                <div class="d-flex mb-3">
                    <i class="bi bi-geo-alt-fill me-3 fs-4"></i>
                    <p class="mb-0">Số 123, Đường Thông Minh, Quận 1, TP. Hồ Chí Minh</p>
                </div>
                <div class="d-flex mb-3">
                    <i class="bi bi-telephone-fill me-3 fs-4"></i>
                    <p class="mb-0">Hotline: 1900-xxxx (24/7)</p>
                </div>
                <div class="d-flex mb-4">
                    <i class="bi bi-envelope-fill me-3 fs-4"></i>
                    <p class="mb-0">support@benhviensmart.vn</p>
                </div>

                <div class="rounded-3 overflow-hidden mt-auto">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.42416741976!2d106.698305374805!3d10.775795189373053!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f385570472f%3A0x118efce14e86d01!2zRGluaCDEkOG7mWMgTOG6rXA!5e0!3m2!1svi!2s!4v1700000000000"
                            width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0 shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    </div>
                }

                <form asp-action="SendContact" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Họ và tên</label>
                            <input asp-for="FullName" class="form-control bg-light" placeholder="Nguyễn Văn A" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Email liên hệ</label>
                            <input asp-for="Email" type="email" class="form-control bg-light" placeholder="name@example.com" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Chủ đề</label>
                        <select asp-for="Subject" class="form-select bg-light">
                            <option value="Góp ý dịch vụ">Góp ý dịch vụ</option>
                            <option value="Hỏi đáp y tế">Hỏi đáp y tế</option>
                            <option value="Báo lỗi hệ thống">Báo lỗi hệ thống</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Nội dung lời nhắn</label>
                        <textarea asp-for="Message" class="form-control bg-light" rows="5" placeholder="Chúng tôi có thể giúp gì cho bạn?" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 rounded-pill shadow-sm">
                        <i class="bi bi-send me-2"></i>GỬI GÓP Ý NGAY
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>