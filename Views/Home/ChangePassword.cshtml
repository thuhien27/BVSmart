@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-warning bg-opacity-75 text-dark py-3">
                    <h5 class="mb-0 fw-bold text-center">
                        <i class="bi bi-shield-lock-fill"></i> THAY ĐỔI MẬT KHẨU
                    </h5>
                </div>

                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger shadow-sm">
                            <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                        </div>
                    }

                    <p class="text-muted small mb-4 text-center">
                        Bạn nên sử dụng mật khẩu mạnh (bao gồm chữ, số và ký tự đặc biệt) để tránh cảnh báo rò rỉ từ trình duyệt.
                    </p>

                    <form asp-action="ChangePassword" asp-controller="Home" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                                <input type="password" name="oldPassword" class="form-control" placeholder="Nhập mật khẩu đang dùng" required />
                            </div>
                        </div>

                        <hr class="my-4 text-muted">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary">Mật khẩu mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-shield-plus"></i></span>
                                <input type="password" name="newPassword" class="form-control" placeholder="Nhập mật khẩu mới" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary">Xác nhận mật khẩu mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-check-all"></i></span>
                                <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary fw-bold py-2 shadow-sm">
                                <i class="bi bi-save"></i> CẬP NHẬT NGAY
                            </button>
                            <a asp-action="Profile" class="btn btn-outline-secondary py-2">
                                Quay lại trang cá nhân
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>// Bạn có thể thêm JS kiểm tra độ mạnh yếu của mật khẩu ở đây nếu muốn</script>
}