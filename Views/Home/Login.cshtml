@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - BenhvienSmart</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .login-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        .btn-login {
            background: #0d6efd;
            border: none;
            border-radius: 50px;
            padding: 10px;
            font-weight: bold;
            transition: 0.3s;
        }

            .btn-login:hover {
                background: #0b5ed7;
                transform: scale(1.02);
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="text-center mb-4">
                    <h1 class="fw-bold text-primary">🏥 BVSmart</h1>
                    <p class="text-muted">Hệ thống quản lý bệnh viện thông minh</p>
                </div>

                <div class="card login-card p-4">
                    <div class="card-body">
                        <h4 class="text-center fw-bold mb-4">ĐĂNG NHẬP</h4>

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger py-2 small text-center">
                                <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
                            </div>
                        }

                        <form asp-controller="Home" asp-action="VerifyLogin" method="post">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Tên đăng nhập</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                                    <input type="text" name="username" class="form-control bg-light border-start-0" placeholder="Nhập tài khoản..." required autofocus>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <label class="form-label small fw-bold">Mật khẩu</label>
                                    <a asp-action="ForgotPassword" class="text-decoration-none small">Quên mật khẩu?</a>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-key"></i></span>
                                    <input type="password" name="password" class="form-control bg-light border-start-0" placeholder="Nhập mật khẩu..." required>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-login w-100 mt-3 shadow-sm">
                                ĐĂNG NHẬP
                            </button>
                        </form>

                        <div class="text-center mt-4">
                            <p class="text-muted small mb-1">Chưa có tài khoản bệnh nhân?</p>
                            <a asp-action="Register" class="fw-bold text-decoration-none text-success">
                                <i class="bi bi-plus-circle me-1"></i>Tạo tài khoản mới
                            </a>
                        </div>
                    </div>
                </div>

                <p class="text-center text-muted mt-4 small">&copy; 2026 BenhvienSmart System</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>