@using BenhvienSmart.Models
@{
    ViewData["Title"] = "Trang chủ - BenhvienSmart";

    // Ép kiểu an toàn ngay từ đầu để tránh các cảnh báo CS8602, CS8604
    var newsList = ViewBag.LatestNews as List<News>;
}

<div class="p-5 mb-4 bg-light rounded-3 shadow-sm border-start border-primary border-5">
    <div class="container-fluid py-5 text-center text-lg-start">
        <h1 class="display-5 fw-bold text-primary">🏥 Hệ thống BenhvienSmart</h1>
        <p class="col-md-8 fs-4 text-muted">
            Giải pháp điều phối lịch khám thông minh, giúp bạn đặt lịch nhanh chóng,
            giảm thời gian chờ đợi và kết nối với bác sĩ chuyên khoa phù hợp nhất.
        </p>
        <div class="d-flex gap-2 justify-content-center justify-content-lg-start">
            <a asp-controller="Appointment" asp-action="Create" class="btn btn-primary btn-lg px-4 shadow">
                <i class="bi bi-calendar-check"></i> Đăng ký khám ngay
            </a>
            <a href="#about" class="btn btn-outline-secondary btn-lg px-4">Tìm hiểu thêm</a>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="p-3 border rounded shadow-sm bg-white card-stat">
                <h2 class="text-primary fw-bold">@(ViewBag.ActiveDoctors ?? 0)+</h2>
                <p class="text-muted mb-0">Bác sĩ chuyên khoa</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 border rounded shadow-sm bg-white card-stat">
                <h2 class="text-success fw-bold">@(ViewBag.TotalSpecialties ?? 0)+</h2>
                <p class="text-muted mb-0">Chuyên khoa đa dạng</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 border rounded shadow-sm bg-white card-stat">
                <h2 class="text-info fw-bold">@(ViewBag.TotalAppointments ?? 0)+</h2>
                <p class="text-muted mb-0">Ca khám đã điều phối</p>
            </div>
        </div>
    </div>
</div>
@if (User?.Identity?.IsAuthenticated == true)@* Tạm thời dùng IsAuthenticated để bạn test cho dễ *@
{
    <div class="container pb-4">
        <div class="card border-0 shadow-sm bg-primary text-white p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0 fw-bold"><i class="bi bi-tools"></i> Công cụ Quản trị viên</h5>
                    <small>Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")</small>
                </div>
                <div>
                    <a asp-controller="Statistics" asp-action="ExportDailyReport" class="btn btn-light fw-bold shadow-sm">
                        <i class="bi bi-file-earmark-spreadsheet"></i> Xuất báo cáo ngày (.CSV)
                    </a>
                </div>
            </div>
        </div>
    </div>
}
<section id="about" class="container py-5">
    <div class="row g-5">
        <div class="col-md-4 text-center">
            <i class="bi bi-cpu fs-1 text-primary"></i>
            <h4 class="mt-3">Điều phối Thông minh</h4>
            <p class="text-muted">Thuật toán Heuristic giúp tìm kiếm khung giờ rảnh và bác sĩ phù hợp nhất cho bạn.</p>
        </div>
        <div class="col-md-4 text-center">
            <i class="bi bi-shield-check fs-1 text-success"></i>
            <h4 class="mt-3">An toàn Bảo mật</h4>
            <p class="text-muted">Thông tin cá nhân và hồ sơ bệnh án được quản lý an toàn theo tiêu chuẩn y tế.</p>
        </div>
        <div class="col-md-4 text-center">
            <i class="bi bi-clock-history fs-1 text-warning"></i>
            <h4 class="mt-3">Tiết kiệm Thời gian</h4>
            <p class="text-muted">Loại bỏ quy trình xếp hàng chờ đợi phức tạp, giúp bạn chủ động hơn trong việc khám bệnh.</p>
        </div>
    </div>
</section>

<div class="container py-5 bg-white rounded shadow-sm mt-5">
    <h3 class="fw-bold mb-4 px-3 border-bottom pb-3 text-secondary">Hoạt động mới nhất</h3>
    <div class="row px-3">
        @if (newsList != null && newsList.Any())
        {
            @foreach (var news in newsList)
            {
                <div class="col-md-4">
                    <div class="border-start border-primary border-4 ps-3 mb-3 h-100 py-1">
                        <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id"
                           class="text-decoration-none text-dark fw-bold d-block hover-link">
                            @(news.Title ?? "Tin tức không tiêu đề")
                        </a>
                        <small class="text-muted">@news.PublishedDate.ToString("dd/MM/yyyy")</small>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 px-3">
                <p class="text-muted fst-italic">Hiện đang cập nhật các hoạt động mới nhất từ bệnh viện...</p>
            </div>
        }
    </div>
</div>

<style>
    .card-stat {
        transition: transform 0.2s;
    }

        .card-stat:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
        }

    .hover-link:hover {
        color: #0d6efd !important;
        text-decoration: underline !important;
    }

    body {
        background-color: #f8f9fa;
    }
</style>