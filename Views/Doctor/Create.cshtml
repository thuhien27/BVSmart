@model BenhvienSmart.Models.Doctor

@{
    ViewData["Title"] = "Thêm Bác sĩ mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> Thêm Bác sĩ mới</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold">Họ và Tên</label>
                            <input asp-for="FullName" class="form-control" placeholder="Ví dụ: BS. Nguyễn Văn An" required />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Specialization" class="form-label fw-bold">Chuyên khoa</label>
                            <select asp-for="Specialization" class="form-select" required>
                                <option value="">-- Chọn chuyên khoa --</option>
                                <option value="Nội tổng quát">Nội tổng quát</option>
                                <option value="Ngoại tổng quát">Ngoại tổng quát</option>
                                <option value="Nhi khoa">Nhi khoa</option>
                                <option value="Sản phụ khoa">Sản phụ khoa</option>
                                <option value="Tai Mũi Họng">Tai Mũi Họng</option>
                                <option value="Răng Hàm Mặt">Răng Hàm Mặt</option>
                                <option value="Mắt">Mắt</option>
                                <option value="Da liễu">Da liễu</option>
                                <option value="Tim mạch">Tim mạch</option>
                                <option value="Hồi sức cấp cứu">Hồi sức cấp cứu</option>
                                <option value="Xét nghiệm">Xét nghiệm</option>
                                <option value="Chẩn đoán hình ảnh">Chẩn đoán hình ảnh</option>
                            </select>
                            <span asp-validation-for="Specialization" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="bacsi@gmail.com" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Phòng ban</label>
                            <label asp-for="DepartmentId" class="form-label fw-bold">ID Phòng ban</label>
                            <input asp-for="DepartmentId" type="number" class="form-control" value="1" />   
                        </div>

                        <div class="mb-3">
                            <label asp-for="DepartmentId" class="form-label fw-bold">ID Phòng ban</label>
                            <input asp-for="DepartmentId" type="number" class="form-control" value="1" />
                            <small class="text-muted">ID liên kết với bảng phòng ban</small>
                        </div>

                        <div class="mb-3 form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label" asp-for="IsActive">Đang làm việc</label>
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">Lưu thông tin</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}